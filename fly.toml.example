app = "camscanner-watermark-web"
primary_region = "nrt"

[build]
  dockerfile = "Dockerfile"

[env]
  MAX_UPLOAD_BYTES = "52428800"
  MAX_FILES = "10"
  RATE_LIMIT_PER_MINUTE = "20"

[http_service]
  internal_port = 8000
  force_https = true
  auto_stop_machines = true
  auto_start_machines = true
  min_machines_running = 0
  processes = ["app"]

[[vm]]
  memory = "512mb"
  cpu_kind = "shared"
  cpus = 1
